# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# secrets / keys / certs (never upload to GitHub or the server)
*.key
*.p12
*.pfx
*.pkcs12
id_rsa
id_rsa.*
*.crt
!.env.example

# editors / IDEs
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# OS cruft
.DS_Store
.DS_Store?
._*
Thumbs.db
.Spotlight-V100
.Trashes

# logs
*.log
logs/

# local tooling & agent artifacts (not part of the app)
.claude/settings.local.json
.playwright-mcp/
.superpowers/

# supabase local CLI state (keep tracked *.sql migrations)
supabase/.branches/
supabase/.temp/
supabase/.env

# raw brand originals — heavy source assets, not served by the app
# (the app uses public/logos/, which stays tracked)
/logo/
